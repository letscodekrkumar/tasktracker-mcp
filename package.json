{
  "name": "tasktracker",
  "version": "1.0.0",
  "description": "A DAG-based task tracking MCP server for bug analysis and investigation workflows",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "tasktracker": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "prepack": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "type-check": "tsc --noEmit",
    "benchmark": "node dist/benchmark.js",
    "security:audit": "npm audit",
    "security:scan": "npm run build && npm audit --audit-level=moderate",
    "ci": "npm run type-check && npm run lint && npm run format:check && npm run test:coverage",
    "clean": "rm -rf dist coverage",
    "prepare": "husky install"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "task-tracking",
    "dag",
    "bug-analysis",
    "investigation",
    "dependency-graph"
  ],
  "author": "TaskTracker Contributors",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/benchmark": "^2.1.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "benchmark": "^2.1.4",
    "eslint": "^8.57.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
